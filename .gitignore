# Python cache and local environments
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
ENV/
.env
.env.*
!.env.example

# Python tooling and test output
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.egg-info/
build/
dist/

# Credentials, certificates and machine-specific configuration
*.pem
*.key
*.p12
*.pfx
id_rsa*
credentials.json
secrets.json
local_settings.py

# TensorRT / ONNX / training binaries and checkpoints
*.engine
*.onnx
*.pt
*.pth
*.ckpt
*.weights

# Datasets and generated training outputs
dataset/
data/
runs/
models/runs/
models/eval_results/
models/*.pt
models/*.onnx
models/*.engine

# Runtime logs and temporary process files
*.log
*.pid
*.sock
tmp/
temp/
jetson/*probe*

# Generated verification media; keep JSON/Markdown reports
artifacts/*.jpg
artifacts/*.jpeg
artifacts/*.png
artifacts/*.mp4
artifacts/*.avi
artifacts/*.log

# Android and Gradle build output
.gradle/
android/.gradle/
android/**/build/
android/local.properties
*.apk
*.aab

# IDE and operating-system files
.idea/
.vscode/
*.iml
.DS_Store
Thumbs.db
